# ---------------------------------------------------------------------------
# Quote form — email notifications via Resend
#
# Setup (one-time):
#   1. Sign up at https://resend.com (free tier: 3,000/mo, 100/day).
#   2. Create an API key under "API Keys" and paste it below.
#   3. (Recommended) Verify your domain so emails come from leads@corevance.ca
#      instead of onboarding@resend.dev. Until verified, keep the default FROM.
#   4. Copy this file to .env.local and fill in the key:
#        cp .env.example .env.local
#   5. Restart `npm run dev`.
#
# If RESEND_API_KEY is missing the form still works — submissions go to the
# Google Form as before, you just won't get an inbox notification.
# ---------------------------------------------------------------------------

RESEND_API_KEY=

# Inbox that receives new lead notifications.
LEAD_NOTIFICATION_EMAIL=corevancesales@gmail.com

# FROM address shown in the notification email.
# Use the Resend testing sender until your domain is verified.
RESEND_FROM="Corevance Leads <onboarding@resend.dev>"
